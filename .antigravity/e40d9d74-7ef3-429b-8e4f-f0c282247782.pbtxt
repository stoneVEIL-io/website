  file_change {
    absolute_path_uri: "file:///public/landing.html"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "<!DOCTYPE html>\n<html lang=\"en\" class=\"scroll-smooth\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Automate the Busywork. Run the Business. | stoneVEIL Operations LLC</title>\n  \n  <!-- SEO Meta Tags -->\n  <meta name=\"description\" content=\"Get a Free Workflow Audit from stoneVEIL Operations LLC. We build custom AI automations that save SMBs 10-20+ hours per week.\">\n  \n  <!-- Font Integration -->\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap\" rel=\"stylesheet\">\n  \n  <!-- Tailwind CSS Play CDN -->\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script>\n    tailwind.config = {\n      theme: {\n        extend: {\n          colors: {\n            brand: {\n              navy: \'#0F1929\',\n              slate: \'#1E293B\',\n              indigo: \'#4F46E5\',\n              indigoLight: \'#818CF8\',\n              amber: \'#F59E0B\',\n              bgLight: \'#F8F9FB\'\n            }\n          },\n          fontFamily: {\n            sans: [\'Inter\', \'-apple-system\', \'BlinkMacSystemFont\', \'Segoe UI\', \'sans-serif\'],\n            display: [\'Space Grotesk\', \'sans-serif\']\n          }\n        }\n      }\n    }\n  </script>\n\n  <style>\n    /* Custom utility styles and smooth transitions */\n    .fade-in-section {\n      opacity: 0;\n      transform: translateY(20px);\n      transition: opacity 0.6s ease-out, transform 0.6s ease-out;\n      will-change: opacity, transform;\n    }\n    .fade-in-section.is-visible {\n      opacity: 1;\n      transform: translateY(0);\n    }\n    \n    /* Custom glow-effects for trust and modern aesthetic */\n    .indigo-glow {\n      box-shadow: 0 0 40px -5px rgba(79, 70, 229, 0.15);\n    }\n    \n    /* Interactive accordion icon transitions */\n    .accordion-content {\n      max-height: 0;\n      overflow: hidden;\n      transition: max-height 0.3s ease-out, padding 0.3s ease-out;\n    }\n    \n    .accordion-open .accordion-content {\n      max-height: 500px;\n    }\n  </style>\n</head>\n<body class=\"bg-white text-slate-800 font-sans antialiased selection:bg-brand-indigo selection:text-white\">\n\n  <!-- Header / Navigation (Sticky, Minimal) -->\n  <header class=\"sticky top-0 z-50 bg-brand-navy/95 backdrop-blur-md border-b border-white/5 py-4 px-6 md:px-12 transition-all duration-300\">\n    <div class=\"max-w-7xl mx-auto flex items-center justify-between\">\n      <!-- Logo -->\n      <a href=\"#\" class=\"flex items-center space-x-3 text-white focus:outline-none\">\n        <svg class=\"w-8 h-8 text-brand-indigo\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <path d=\"M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5\"/>\n        </svg>\n        <span class=\"font-display font-bold text-lg tracking-tight\">stone<span class=\"text-brand-indigo\">VEIL</span> <span class=\"text-xs uppercase font-sans font-semibold text-slate-400 tracking-widest px-1.5 py-0.5 bg-white/5 rounded border border-white/10 ml-2\">Ops</span></span>\n      </a>\n      \n      <!-- CTA Button -->\n      <div>\n        <a href=\"#audit-form-section\" class=\"bg-brand-indigo hover:bg-indigo-700 text-white font-medium text-sm md:text-base py-2.5 px-5 rounded-lg transition-all duration-200 transform hover:-translate-y-0.5 active:translate-y-0 shadow-lg shadow-indigo-500/20 active:shadow-none\">\n          Book Free Audit\n        </a>\n      </div>\n    </div>\n  </header>\n\n  <!-- SECTION 1: HERO (Above the fold, Max Impact) -->\n  <section class=\"relative bg-brand-navy dark text-white pt-16 pb-24 md:pt-24 md:pb-32 px-6 overflow-hidden\">\n    <!-- Ambient Background Accents -->\n    <div class=\"absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-indigo/10 rounded-full blur-[120px] pointer-events-none\"></div>\n    <div class=\"absolute bottom-10 right-10 w-[300px] h-[300px] bg-brand-amber/5 rounded-full blur-[90px] pointer-events-none\"></div>\n\n    <div class=\"max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center relative z-10\">\n      \n      <!-- Hero Copy -->\n      <div class=\"lg:col-span-7 flex flex-col items-start space-y-6 md:space-y-8\">\n        <!-- Message Match/Hook -->\n        <span class=\"inline-flex items-center space-x-2 bg-white/5 border border-white/10 rounded-full px-3.5 py-1.5 text-xs md:text-sm font-medium tracking-wide text-brand-indigoLight uppercase font-display\">\n          <span>\342\232\241 SMB Workflow Automation Specialist</span>\n        </span>\n        \n        <h1 class=\"text-4xl md:text-5xl lg:text-6xl font-display font-bold leading-tight tracking-tight\">\n          Stop Losing <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-brand-indigoLight to-blue-400\">15+ Hours/Week</span> to Work Your Business Could Do Itself.\n        </h1>\n        \n        <p class=\"text-lg md:text-xl text-slate-300 max-w-2xl leading-relaxed\">\n          We design and deploy custom AI workflow automations for small businesses that eliminate manual data entry, missed follow-ups, and broken systems \342\200\224 in days, not months.\n        </p>\n        \n        <!-- Call to Actions -->\n        <div class=\"w-full sm:w-auto flex flex-col sm:flex-row items-stretch sm:items-center gap-4 pt-2\">\n          <a href=\"#audit-form-section\" class=\"bg-brand-amber hover:bg-amber-500 text-brand-navy font-bold text-center py-4 px-8 rounded-lg shadow-xl shadow-amber-500/20 transition-all duration-200 transform hover:-translate-y-0.5 active:translate-y-0 text-base\">\n            Book Your Free Workflow Audit &rarr;\n          </a>\n          <a href=\"#how-it-works-section\" class=\"bg-transparent hover:bg-white/5 text-white font-semibold text-center py-4 px-8 rounded-lg border border-white/20 transition-all duration-200 text-base\">\n            See How It Works\n          </a>\n        </div>\n        \n        <!-- Trust Bar (Micro Proof Stats) -->\n        <div class=\"w-full pt-6 border-t border-white/10 grid grid-cols-3 gap-4\">\n          <div>\n            <!-- [REPLACE: Description below is marked for customization with real client counts] -->\n            <div class=\"text-xl md:text-2xl font-bold font-display text-white\">127+</div>\n            <div class=\"text-xs md:text-sm text-slate-400\">SMBs Automated <!-- [REPLACE: total clients placeholder] --></div>\n          </div>\n          <div>\n            <!-- [REPLACE: description below is marked for customization with audited results] -->\n            <div class=\"text-xl md:text-2xl font-bold font-display text-transparent bg-clip-text bg-gradient-to-r from-green-400 to-emerald-300\">11 Hrs</div>\n            <div class=\"text-xs md:text-sm text-slate-400\">Avg. Weekly Saved <!-- [REPLACE: hours saved value] --></div>\n          </div>\n          <div>\n            <!-- [REPLACE: description below is marked for customization with ROI stats] -->\n            <div class=\"text-xl md:text-2xl font-bold font-display text-brand-indigoLight\">&lt;30 Days</div>\n            <div class=\"text-xs md:text-sm text-slate-400\">Avg. Full ROI <!-- [REPLACE: ROI timeframe] --></div>\n          </div>\n        </div>\n      </div>\n      \n      <!-- Hero Interactive CSS Animation: Chaos to Clarity -->\n      <div class=\"lg:col-span-5 w-full flex justify-center relative\">\n        <div class=\"w-full max-w-md aspect-square bg-slate-900/60 border border-white/10 rounded-2xl p-6 md:p-8 flex flex-col justify-between relative shadow-2xl overflow-hidden group\">\n          \n          <!-- Outer dynamic ring -->\n          <div class=\"absolute -inset-0.5 bg-gradient-to-r from-brand-indigo to-brand-indigoLight rounded-2xl opacity-20 group-hover:opacity-30 blur transition duration-500\"></div>\n          \n          <div class=\"relative z-10 h-full flex flex-col justify-between\">\n            <!-- Stage 1 Header -->\n            <div class=\"flex items-center justify-between border-b border-white/10 pb-3\">\n              <span class=\"text-xs font-mono text-slate-400\">SYSTEM VISUALIZATION</span>\n              <span class=\"px-2 py-0.5 rounded bg-brand-indigo/20 text-brand-indigoLight text-[10px] font-semibold uppercase animate-pulse\">Live Simulator</span>\n            </div>\n            \n            <!-- Graphic Arena -->\n            <div class=\"relative flex-1 flex flex-col items-center justify-center py-6\">\n              \n              <!-- Segment 1: Scatter (Chaos) left-ish -->\n              <div class=\"absolute left-4 top-1/4 flex flex-col space-y-2 opacity-50 space-y-4 animate-bounce\" style=\"animation-duration: 4s;\">\n                <div class=\"flex items-center space-x-2 bg-red-500/10 border border-red-500/20 rounded px-2.5 py-1\">\n                  <span class=\"w-1.5 h-1.5 rounded-full bg-red-400 block\"></span>\n                  <span class=\"text-[10px] font-mono text-red-200\">Lost Invoice</span>\n                </div>\n                <div class=\"flex items-center space-x-2 bg-orange-500/10 border border-orange-500/20 rounded px-2.5 py-1\">\n                  <span class=\"w-1.5 h-1.5 rounded-full bg-orange-400 block\"></span>\n                  <span class=\"text-[10px] font-mono text-orange-200\">Manual Entry</span>\n                </div>\n              </div>\n              \n              <!-- Center Gear (Automation Core) -->\n              <div class=\"relative z-20 flex flex-col items-center\">\n                <div class=\"w-24 h-24 rounded-full bg-brand-navy border border-brand-indigo/30 flex items-center justify-center relative shadow-lg\">\n                  <div class=\"absolute inset-0 bg-brand-indigo/10 rounded-full animate-ping pointer-events-none\" style=\"animation-duration: 2s;\"></div>\n                  \n                  <!-- CSS rotating gear -->\n                  <svg class=\"w-12 h-12 text-brand-indigoLight animate-spin\" style=\"animation-duration: 10s;\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\">\n                    <circle cx=\"12\" cy=\"12\" r=\"3\" />\n                    <path d=\"M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z\" />\n                  </svg>\n                </div>\n                <span class=\"mt-3 text-[10px] uppercase tracking-wider font-semibold text-slate-400\">stoneVEIL Pipeline</span>\n              </div>\n              \n              <!-- Segment 3: Clarity (Outcomes) right-ish -->\n              <div class=\"absolute right-4 bottom-1/4 flex flex-col space-y-2 opacity-90 animate-pulse\">\n                <div class=\"flex items-center space-x-2 bg-green-500/10 border border-green-500/20 rounded px-2.5 py-1\">\n                  <svg class=\"w-3.5 h-3.5 text-green-400\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z\" />\n                  </svg>\n                  <span class=\"text-[10px] font-mono text-green-200\">Sync Complete</span>\n                </div>\n                <div class=\"flex items-center space-x-2 bg-indigo-500/10 border border-indigo-500/20 rounded px-2.5 py-1\">\n                  <svg class=\"w-3.5 h-3.5 text-indigo-400\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\">\n                    <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z\" />\n                  </svg>\n                  <span class=\"text-[10px] font-mono text-indigo-200\">Follow-up Dispatched</span>\n                </div>\n              </div>\n              \n              <!-- Laser path graphics -->\n              <svg class=\"absolute inset-0 w-full h-full pointer-events-none\" fill=\"none\">\n                <path d=\"M 50 100 Q 150 110 190 140\" stroke=\"rgba(239, 68, 68, 0.2)\" stroke-width=\"1.5\" stroke-dasharray=\"4 4\" />\n                <path d=\"M 60 170 Q 140 160 190 160\" stroke=\"rgba(249, 115, 22, 0.2)\" stroke-width=\"1.5\" stroke-dasharray=\"4 4\" />\n                <path d=\"M 270 160 Q 320 150 380 180\" stroke=\"rgba(16, 185, 129, 0.4)\" stroke-width=\"1.5\" />\n                <path d=\"M 260 180 Q 330 200 370 130\" stroke=\"rgba(79, 70, 229, 0.4)\" stroke-width=\"1.5\" />\n              </svg>\n            </div>\n            \n            <!-- Realtime Metrics Ticker -->\n            <div class=\"border-t border-white/10 pt-3 flex items-center justify-between text-[11px] text-slate-400 font-mono\">\n              <span>ACTIVE DISPATCH: <span class=\"text-green-400\">READY</span></span>\n              <span>EFFICIENCY: +86%</span>\n            </div>\n          </div>\n        </div>\n      </div>\n      \n    </div>\n  </section>\n\n  <!-- SECTION 2: PAIN AGITATION (Emotional Hook) -->\n  <section class=\"py-24 px-6 bg-brand-bgLight\">\n    <div class=\"max-w-7xl mx-auto flex flex-col items-center space-y-12\">\n      <!-- Title block -->\n      <div class=\"text-center max-w-3xl space-y-4\">\n        <h2 class=\"text-3xl md:text-4xl font-display font-bold text-brand-navy\">Sound familiar?</h2>\n        <p class=\"text-lg text-slate-600\">The hidden time-tax on SMB operations. You started a business to grow it \342\200\224 not to be chained to administrative routine.</p>\n      </div>\n      \n      <!-- 6-Card Grid of Pain Points -->\n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 w-full\">\n        <!-- Pain Card 1 -->\n        <div class=\"bg-white border border-slate-100 p-6 rounded-xl hover:shadow-xl hover:border-indigo-500/20 transition-all duration-300 flex space-x-4 items-start\">\n          <div class=\"p-3 bg-red-50 text-red-500 rounded-lg shrink-0\">\n            <svg class=\"w-6 h-6\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z\" />\n            </svg>\n          </div>\n          <div class=\"space-y-1.5\">\n            <h3 class=\"font-display font-bold text-slate-900\">Spreadsheet Copy-Pasta</h3>\n            <p class=\"text-sm text-slate-600 leading-relaxed\">Manually copying and pasting customer data between your emails, spreadsheets, and legacy CRMs.</p>\n          </div>\n        </div>\n        \n        <!-- Pain Card 2 -->\n        <div class=\"bg-white border border-slate-100 p-6 rounded-xl hover:shadow-xl hover:border-indigo-500/20 transition-all duration-300 flex space-x-4 items-start\">\n          <div class=\"p-3 bg-red-50 text-red-500 rounded-lg shrink-0\">\n            <svg class=\"w-6 h-6\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z\" />\n            </svg>\n          </div>\n          <div class=\"space-y-1.5\">\n            <h3 class=\"font-display font-bold text-slate-900\">Leads Falling Through</h3>\n            <p class=\"text-sm text-slate-600 leading-relaxed\">Incoming hot leads going cold because custom follow-up emails weren\342\200\231t sent within the same hour.</p>\n          </div>\n        </div>\n\n        <!-- Pain Card 3 -->\n        <div class=\"bg-white border border-slate-100 p-6 rounded-xl hover:shadow-xl hover:border-indigo-500/20 transition-all duration-300 flex space-x-4 items-start\">\n          <div class=\"p-3 bg-red-50 text-red-500 rounded-lg shrink-0\">\n            <svg class=\"w-6 h-6\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z\" />\n            </svg>\n          </div>\n          <div class=\"space-y-1.5\">\n            <h3 class=\"font-display font-bold text-slate-900\">Chasing Invoices</h3>\n            <p class=\"text-sm text-slate-600 leading-relaxed\">Tracking payments, sending reminders, and updating accounts receivable parameters by hand every month.</p>\n          </div>\n        </div>\n\n        <!-- Pain Card 4 -->\n        <div class=\"bg-white border border-slate-100 p-6 rounded-xl hover:shadow-xl hover:border-indigo-500/20 transition-all duration-300 flex space-x-4 items-start\">\n          <div class=\"p-3 bg-red-50 text-red-500 rounded-lg shrink-0\">\n            <svg class=\"w-6 h-6\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M11 3.055A9.003 9.003 0 1020.945 13H11V3.055z\" />\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z\" />\n            </svg>\n          </div>\n          <div class=\"space-y-1.5\">\n            <h3 class=\"font-display font-bold text-slate-900\">Manual Reporting</h3>\n            <p class=\"text-sm text-slate-600 leading-relaxed\">Staff spending chunks of their day on pipeline metrics, KPI summaries, and reports that should be instant.</p>\n          </div>\n        </div>\n\n        <!-- Pain Card 5 -->\n        <div class=\"bg-white border border-slate-100 p-6 rounded-xl hover:shadow-xl hover:border-indigo-500/20 transition-all duration-300 flex space-x-4 items-start\">\n          <div class=\"p-3 bg-red-50 text-red-500 rounded-lg shrink-0\">\n            <svg class=\"w-6 h-6\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z\" />\n            </svg>\n          </div>\n          <div class=\"space-y-1.5\">\n            <h3 class=\"font-display font-bold text-slate-900\">Radio Silence After Hours</h3>\n            <p class=\"text-sm text-slate-600 leading-relaxed\">Customer questions go unanswered overnight, leading them straight to competitors who reply instantly.</p>\n          </div>\n        </div>\n\n        <!-- Pain Card 6 -->\n        <div class=\"bg-white border border-slate-100 p-6 rounded-xl hover:shadow-xl hover:border-indigo-500/20 transition-all duration-300 flex space-x-4 items-start\">\n          <div class=\"p-3 bg-red-50 text-red-500 rounded-lg shrink-0\">\n            <svg class=\"w-6 h-6\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z\" />\n            </svg>\n          </div>\n          <div class=\"space-y-1.5\">\n            <h3 class=\"font-display font-bold text-slate-900\">Scheduling Pinball</h3>\n            <p class=\"text-sm text-slate-600 leading-relaxed\">Playing back-and-forth email tag for basic meeting slots, eating up massive chunks of your morning.</p>\n          </div>\n        </div>\n      </div>\n      \n      <!-- Subtitle bold wrap -->\n      <div class=\"text-center pt-4\">\n        <p class=\"text-xl font-display font-semibold text-brand-navy max-w-xl\">\n          \"Every single one of these tasks is fully automatable. Most take less than a week to deploy.\"\n        </p>\n      </div>\n    </div>\n  </section>\n\n  <!-- SECTION 3: SOLUTION / HOW IT WORKS -->\n  <section id=\"how-it-works-section\" class=\"py-24 px-6 bg-white overflow-hidden\">\n    <div class=\"max-w-7xl mx-auto flex flex-col items-center space-y-16\">\n      \n      <!-- H2 -->\n      <div class=\"text-center max-w-3xl space-y-4\">\n        <h2 class=\"text-3xl md:text-4xl font-display font-bold text-brand-navy\">How We Turn Your Bottlenecks Into Automated Workflows</h2>\n        <p class=\"text-lg text-slate-600\">A structured process designed specifically for busy operators. No jargon, no code templates, and minimal commitment.</p>\n      </div>\n      \n      <!-- Step flow -->\n      <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-12 lg:gap-8 items-stretch w-full relative\">\n        \n        <!-- Connection Line (Desktop only) -->\n        <div class=\"hidden lg:block absolute top-[4.5rem] left-[20%] right-[20%] h-0.5 border-t-2 border-dashed border-slate-200 pointer-events-none\"></div>\n\n        <!-- Step 1 -->\n        <div class=\"flex flex-col items-center text-center space-y-4 bg-brand-bgLight lg:bg-transparent p-8 lg:p-0 rounded-2xl relative\">\n          <div class=\"w-16 h-16 rounded-full bg-brand-indigo text-white font-bold text-lg flex items-center justify-center relative z-10 shadow-lg shadow-indigo-500/10\">\n            <svg class=\"w-7 h-7 text-white\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M15 12a3 3 0 11-6 0 3 3 0 016 0z\" />\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z\" />\n            </svg>\n          </div>\n          <div class=\"space-y-2\">\n            <h3 class=\"text-xl font-display font-bold text-brand-navy\">Step 1 \342\200\224 Discovery Audit</h3>\n            <p class=\"text-sm text-brand-indigo font-semibold tracking-wide uppercase px-2 py-0.5 bg-indigo-50 rounded inline-block\">Timeframe: 30 Mins</p>\n            <p class=\"text-slate-600 leading-relaxed max-w-sm\">We map your biggest custom bottleneck tasks, map software tools you already use, and draft estimated baseline ROI estimates.</p>\n          </div>\n        </div>\n        \n        <!-- Step 2 -->\n        <div class=\"flex flex-col items-center text-center space-y-4 bg-brand-bgLight lg:bg-transparent p-8 lg:p-0 rounded-2xl relative\">\n          <div class=\"w-16 h-16 rounded-full bg-brand-navy border border-brand-indigo text-white font-bold text-lg flex items-center justify-center relative z-10 shadow-lg\">\n            <svg class=\"w-7 h-7 text-brand-indigoLight\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4\" />\n            </svg>\n          </div>\n          <div class=\"space-y-2\">\n            <h3 class=\"text-xl font-display font-bold text-brand-navy\">Step 2 \342\200\224 Custom Build</h3>\n            <p class=\"text-sm text-brand-indigo font-semibold tracking-wide uppercase px-2 py-0.5 bg-indigo-50 rounded inline-block\">Timeframe: 5-7 Days</p>\n            <p class=\"text-slate-600 leading-relaxed max-w-sm\">Our agency team architects, connects, and thoroughly tests your automation pipelines. You see drafts in staging within 4 days.</p>\n          </div>\n        </div>\n\n        <!-- Step 3 -->\n        <div class=\"flex flex-col items-center text-center space-y-4 bg-brand-bgLight lg:bg-transparent p-8 lg:p-0 rounded-2xl relative\">\n          <div class=\"w-16 h-16 rounded-full bg-emerald-500 text-white font-bold text-lg flex items-center justify-center relative z-10 shadow-lg shadow-emerald-500/10\">\n            <svg class=\"w-7 h-7 text-white\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\">\n              <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M13 10V3L4 14h7v7l9-11h-7z\" />\n            </svg>\n          </div>\n          <div class=\"space-y-2\">\n            <h3 class=\"text-xl font-display font-bold text-brand-navy\">Step 3 \342\200\224 Run & Optimize</h3>\n            <p class=\"text-sm text-emerald-600 font-semibold tracking-wide uppercase px-2 py-0.5 bg-emerald-50 rounded inline-block\">Outcome: Permanent Freedom</p>\n            <p class=\"text-slate-600 leading-relaxed max-w-sm\">Your business workflows execute precisely. Leads flow smoothly, files clean themselves, and you capture your valuable focus back.</p>\n          </div>\n        </div>\n\n      </div>\n\n      <!-- Audit Hook CTA -->\n      <div class=\"pt-8\">\n        <a href=\"#audit-form-section\" class=\"inline-flex items-center space-x-3 bg-brand-navy hover:bg-brand-slate text-white font-bold py-4 px-8 rounded-lg transition-all duration-200 transform hover:-translate-y-0.5\">\n          <span>Start with a Free Audit \342\200\224 No Commitment</span>\n          <svg class=\"w-5 h-5 text-brand-indigoLight\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\">\n            <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M13 7l5 5m0 0l-5 5m5-5H6\" />\n          </svg>\n        </a>\n      </div>\n\n    </div>\n  </section>\n\n  <!-- SECTION 4: SOCIAL PROOF (Trust & Credibility) -->\n  <section class=\"py-24 px-6 bg-brand-bgLight border-t border-slate-100\">\n    <div class=\"max-w-7xl mx-auto flex flex-col items-center space-y-16\">\n      <!-- Title block -->\n      <div class=\"text-center max-w-3xl space-y-4\">\n        <span class=\"text-brand-indigo uppercase text-xs md:text-sm font-semibold tracking-widest font-display\">Client Proof</span>\n        <h2 class=\"text-3xl md:text-4xl font-display font-bold text-brand-navy\">What SMB Owners Are Saying</h2>\n        <p class=\"text-lg text-slate-600\">Actual financial and productivity returns from regular operations transformed by custom AI workflows.</p>\n      </div>\n\n      <!-- 3 Testimonial Cards -->\n      <!-- [PLACEHOLDER \342\200\224 REPLACE WITH REAL TESTIMONIALS] -->\n      <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 w-full\">\n        \n        <!-- Card 1 -->\n        <div class=\"bg-white p-8 rounded-xl border border-slate-100 flex flex-col justify-between shadow-sm relative group hover:shadow-md transition-all duration-300\">\n          <span class=\"absolute top-4 right-6 text-slate-100 text-6xl font-serif pointer-events-none group-hover:text-indigo-100 transition-colors\">&ldquo;</span>\n          <div class=\"space-y-4\">\n            <!-- Specific result highlight tag -->\n            <div class=\"inline-block bg-teal-50 border border-teal-100 text-teal-700 text-xs font-bold font-mono px-2.5 py-1 rounded\">\n              \360\237\223\212 Saved 14 hours/week & KPI tracking automated\n            </div>\n            <!-- Quote -->\n            <!-- [PLACEHOLDER \342\200\224 REPLACE WITH REAL TESTIMONIAL] -->\n            <p class=\"text-slate-600 text-sm leading-relaxed italic relative z-10\">\n              \"We used to waste nearly two days a week manually copying client data from forms into spreadsheets and manually alerting account reps. stoneVEIL fully automated the client data ingest and pipeline CRM cards. It performs perfectly.\"\n            </p>\n          </div>\n          \n          <div class=\"flex items-center space-x-3 pt-6 border-t border-slate-50 mt-6 shrink-0\">\n            <div class=\"w-10 h-10 rounded-full bg-slate-200 flex items-center justify-center font-display font-bold text-slate-600\">\n              MC\n            </div>\n            <div>\n              <p class=\"text-sm font-bold text-slate-900\">Marcus Chen</p>\n              <p class=\"text-xs text-slate-500\">Founder, Chen Realty Partners // Real Estate</p>\n            </div>\n          </div>\n        </div>\n\n        <!-- Card 2 -->\n        <div class=\"bg-white p-8 rounded-xl border border-slate-100 flex flex-col justify-between shadow-sm relative group hover:shadow-md transition-all duration-300\">\n          <span class=\"absolute top-4 right-6 text-slate-100 text-6xl font-serif pointer-events-none group-hover:text-indigo-100 transition-colors\">&ldquo;</span>\n          <div class=\"space-y-4\">\n            <!-- Specific result highlight tag -->\n            <div class=\"inline-block bg-teal-50 border border-teal-100 text-teal-700 text-xs font-bold font-mono px-2.5 py-1 rounded\">\n              \360\237\216\257 Closed 30% more inbound consulting leads\n            </div>\n            <!-- Quote -->\n            <!-- [PLACEHOLDER \342\200\224 REPLACE WITH REAL TESTIMONIAL] -->\n            <p class=\"text-slate-600 text-sm leading-relaxed italic relative z-10\">\n              \"I didn\'t think a system chatbot could substitute for standard contact forms. Instead, customers converse naturally, book consulting reviews right on my calendar, and automated followups go out instantly. Lead capture is at an all-time high.\"\n            </p>\n          </div>\n          \n          <div class=\"flex items-center space-x-3 pt-6 border-t border-slate-50 mt-6 shrink-0\">\n            <div class=\"w-10 h-10 rounded-full bg-slate-200 flex items-center justify-center font-display font-bold text-slate-600\">\n              SD\n            </div>\n            <div>\n              <p class=\"text-sm font-bold text-slate-900\">Sarah Dunlap</p>\n              <p class=\"text-xs text-slate-500\">Managing Partner, Dunlap Law Firm // Legal</p>\n            </div>\n          </div>\n        </div>\n\n        <!-- Card 3 -->\n        <div class=\"bg-white p-8 rounded-xl border border-slate-100 flex flex-col justify-between shadow-sm relative group hover:shadow-md transition-all duration-300\">\n          <span class=\"absolute top-4 right-6 text-slate-100 text-6xl font-serif pointer-events-none group-hover:text-indigo-100 transition-colors\">&ldquo;</span>\n          <div class=\"space-y-4\">\n            <!-- Specific result highlight tag -->\n            <div class=\"inline-block bg-teal-50 border border-teal-100 text-teal-700 text-xs font-bold font-mono px-2.5 py-1 rounded\">\n              \342\217\263 Automated reporting + billing error drops to 0%\n            </div>\n            <!-- Quote -->\n            <!-- [PLACEHOLDER \342\200\224 REPLACE WITH REAL TESTIMONIAL] -->\n            <p class=\"text-slate-600 text-sm leading-relaxed italic relative z-10\">\n              \"Invoicing used to be a major monthly chore, hand-matching customer timesheets. Programmatic APIs now feed everything directly into Stripe and QuickBooks. We receive payments faster, with absolute zero clerical error.\"\n            </p>\n          </div>\n          \n          <div class=\"flex items-center space-x-3 pt-6 border-t border-slate-50 mt-6 shrink-0\">\n            <div class=\"w-10 h-10 rounded-full bg-slate-200 flex items-center justify-center font-display font-bold text-slate-600\">\n              JL\n            </div>\n            <div>\n              <p class=\"text-sm font-bold text-slate-900\">Jim Larrison</p>\n              <p class=\"text-xs text-slate-500\">Operations Director, Apex Medical Lab // Medical</p>\n            </div>\n          </div>\n        </div>\n\n      </div>\n\n      <!-- Industry Logo strip -->\n      <!-- [ADD CLIENT LOGOS] / Trusted Industries -->\n      <div class=\"w-full pt-12 border-t border-slate-200\">\n        <p class=\"text-center font-display text-xs text-slate-400 font-semibold tracking-widest uppercase mb-6\">TRUSTED BY SMB OPERATORS ACROSS CRITICAL SECTORS</p>\n        <div class=\"grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-6 items-center text-center\">\n          \n          <div class=\"bg-white/80 rounded-lg p-3 border border-slate-150 flex flex-col items-center justify-center space-y-1 bg-white hover:border-indigo-500/20 transition duration-200\">\n            <span class=\"text-xl\">\360\237\217\242</span>\n            <span class=\"text-xs font-semibold text-slate-500 uppercase tracking-wider\">Real Estate</span>\n          </div>\n\n          <div class=\"bg-white/80 rounded-lg p-3 border border-slate-150 flex flex-col items-center justify-center space-y-1 bg-white hover:border-indigo-500/20 transition duration-200\">\n            <span class=\"text-xl\">\342\232\226\357\270\217</span>\n            <span class=\"text-xs font-semibold text-slate-500 uppercase tracking-wider\">Law Firms</span>\n          </div>\n\n          <div class=\"bg-white/80 rounded-lg p-3 border border-slate-150 flex flex-col items-center justify-center space-y-1 bg-white hover:border-indigo-500/20 transition duration-200\">\n            <span class=\"text-xl\">\360\237\251\272</span>\n            <span class=\"text-xs font-semibold text-slate-500 uppercase tracking-wider\">Medical Practices</span>\n          </div>\n\n          <div class=\"bg-white/80 rounded-lg p-3 border border-slate-150 flex flex-col items-center justify-center space-y-1 bg-white hover:border-indigo-500/20 transition duration-200\">\n            <span class=\"text-xl\">\360\237\233\222</span>\n            <span class=\"text-xs font-semibold text-slate-500 uppercase tracking-wider\">Retail & Ecom</span>\n          </div>\n\n          <div class=\"bg-white/80 rounded-lg p-3 border border-slate-150 flex flex-col items-center justify-center space-y-1 bg-white hover:border-indigo-500/20 transition duration-200\">\n            <span class=\"text-xl\">\360\237\215\275\357\270\217</span>\n            <span class=\"text-xs font-semibold text-slate-500 uppercase tracking-wider\">Restaurants</span>\n          </div>\n\n          <div class=\"bg-white/80 rounded-lg p-3 border border-slate-150 flex flex-col items-center justify-center space-y-1 bg-white hover:border-indigo-500/20 transition duration-200\">\n            <span class=\"text-xl\">\360\237\223\243</span>\n            <span class=\"text-xs font-semibold text-slate-500 uppercase tracking-wider\">Agencies</span>\n          </div>\n\n        </div>\n      </div>\n\n    </div>\n  </section>\n\n  <!-- SECTION 5: LEAD CAPTURE FORM (The Conversion Engine) -->\n  <section id=\"audit-form-section\" class=\"py-24 px-6 bg-brand-navy text-white relative overflow-hidden\">\n    <!-- Fluid ambient backplate -->\n    <div class=\"absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-brand-indigo/20 via-brand-navy to-brand-navy pointer-events-none\"></div>\n    \n    <div class=\"max-w-4xl mx-auto relative z-10 space-y-12\">\n      <!-- Header text container -->\n      <div class=\"text-center space-y-4\">\n        <span class=\"inline-flex items-center space-x-2 bg-brand-amber/10 border border-brand-amber/20 rounded-full px-3.5 py-1.5 text-xs font-semibold tracking-wider text-brand-amber uppercase font-display\">\n          \360\237\223\205 No-Cost 30-Minute Discovery Call\n        </span>\n        <h2 class=\"text-4xl font-display font-bold\">Get Your Free Workflow Audit</h2>\n        <p class=\"text-slate-350 text-md md:text-lg max-w-2xl mx-auto leading-relaxed\">\n          In 30 minutes, you\'ll learn exactly which 3 processes to automate first, and an estimated ROI projection. No pitches. No commitments. Genuine analytical value.\n        </p>\n      </div>\n\n      <!-- Lead Capture Form Element -->\n      <div class=\"bg-slate-900/60 border border-white/10 rounded-2xl p-6 md:p-10 shadow-2xl relative\">\n        <form id=\"leadCaptureForm\" onsubmit=\"handleFormSubmission(event)\" class=\"space-y-6\">\n          <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n            <!-- Full Name -->\n            <div class=\"space-y-1.5\">\n              <label for=\"fullName\" class=\"block text-xs font-bold uppercase tracking-wider text-slate-300\">Full Name <span class=\"text-brand-amber\">*</span></label>\n              <input type=\"text\" id=\"fullName\" required class=\"w-full bg-brand-navy border border-white/15 rounded-lg py-3 px-4 text-white placeholder-slate-500 focus:outline-none focus:border-brand-indigo focus:ring-1 focus:ring-brand-indigo transition duration-200 text-sm md:text-base\" placeholder=\"John Doe\">\n            </div>\n\n            <!-- Business Email -->\n            <div class=\"space-y-1.5\">\n              <label for=\"businessEmail\" class=\"block text-xs font-bold uppercase tracking-wider text-slate-300\">Business Email <span class=\"text-brand-amber\">*</span></label>\n              <input type=\"email\" id=\"businessEmail\" required class=\"w-full bg-brand-navy border border-white/15 rounded-lg py-3 px-4 text-white placeholder-slate-500 focus:outline-none focus:border-brand-indigo focus:ring-1 focus:ring-brand-indigo transition duration-200 text-sm md:text-base\" placeholder=\"john@company.com\">\n            </div>\n            \n            <!-- Company Name -->\n            <div class=\"space-y-1.5\">\n              <label for=\"companyName\" class=\"block text-xs font-bold uppercase tracking-wider text-slate-300\">Company Name <span class=\"text-brand-amber\">*</span></label>\n              <input type=\"text\" id=\"companyName\" required class=\"w-full bg-brand-navy border border-white/15 rounded-lg py-3 px-4 text-white placeholder-slate-500 focus:outline-none focus:border-brand-indigo focus:ring-1 focus:ring-brand-indigo transition duration-200 text-sm md:text-base\" placeholder=\"Acme Services Ltd\">\n            </div>\n\n            <!-- Phone Number -->\n            <div class=\"space-y-1.5\">\n              <label for=\"phoneNumber\" class=\"block text-xs font-bold uppercase tracking-wider text-slate-300\">Phone Number <span class=\"text-slate-400 font-normal\">(Optional, for scheduling your call)</span></label>\n              <input type=\"tel\" id=\"phoneNumber\" class=\"w-full bg-brand-navy border border-white/15 rounded-lg py-3 px-4 text-white placeholder-slate-500 focus:outline-none focus:border-brand-indigo focus:ring-1 focus:ring-brand-indigo transition duration-200 text-sm md:text-base\" placeholder=\"(555) 019-2834\">\n            </div>\n          </div>\n\n          <!-- Biggest Time Drain Select dropdown -->\n          <div class=\"space-y-1.5\">\n            <label for=\"timeDrain\" class=\"block text-xs font-bold uppercase tracking-wider text-slate-300\">What is your business\'s biggest time drain? <span class=\"text-brand-amber\">*</span></label>\n            <div class=\"relative\">\n              <select id=\"timeDrain\" required class=\"w-full bg-brand-navy border border-white/15 rounded-lg py-3 px-4 text-white focus:outline-none focus:border-brand-indigo focus:ring-1 focus:ring-brand-indigo transition duration-200 appearance-none text-sm md:text-base cursor-pointer\">\n                <option value=\"\" disabled selected>Select primary operations bottleneck...</option>\n                <option value=\"Customer follow-ups & CRM\">Customer follow-ups & CRM</option>\n                <option value=\"Invoicing & payments\">Invoicing & payments</option>\n                <option value=\"Scheduling & calendar\">Scheduling & calendar</option>\n                <option value=\"Reporting & data entry\">Reporting & data entry</option>\n                <option value=\"Lead generation & intake\">Lead generation & intake</option>\n                <option value=\"Other\">Other (please specify below)</option>\n              </select>\n              <div class=\"absolute inset-y-0 right-4 flex items-center pointer-events-none text-slate-400\">\n                <svg class=\"w-5 h-5\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\">\n                  <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M19 9l-7 7-7-7\" />\n                </svg>\n              </div>\n            </div>\n          </div>\n\n          <!-- Brief process description textarea -->\n          <div class=\"space-y-1.5\">\n            <label for=\"processDetails\" class=\"block text-xs font-bold uppercase tracking-wider text-slate-300\">Briefly describe your current process <span class=\"text-slate-400 font-normal\">(Optional)</span></label>\n            <textarea id=\"processDetails\" rows=\"3\" class=\"w-full bg-brand-navy border border-white/15 rounded-lg py-3 px-4 text-white placeholder-slate-500 focus:outline-none focus:border-brand-indigo focus:ring-1 focus:ring-brand-indigo transition duration-200 text-sm md:text-base resize-none\" placeholder=\"E.g., We manual-format Excel files and copy client fields into QuickBooks...\"></textarea>\n          </div>\n\n          <!-- Submit trigger button -->\n          <div class=\"pt-2\">\n            <button type=\"submit\" class=\"w-full bg-brand-amber hover:bg-amber-500 text-brand-navy font-extrabold py-4 px-6 rounded-lg text-base transform hover:-translate-y-0.5 active:translate-y-0 transition-all duration-200 shadow-xl shadow-amber-500/10 hover:shadow-amber-500/20 cursor-pointer\">\n              Book My Free Audit &rarr;\n            </button>\n            \n            <!-- Under button social proof scarcity -->\n            <!-- [REPLACE: Count below is easily customized with total active users] -->\n            <p class=\"text-center text-xs text-slate-400 mt-3 font-medium\">\n              Join <span class=\"text-brand-amber font-semibold\">127+ SMBs</span> who\'ve already automated their workflows <!-- [REPLACE: count statistic] -->\n            </p>\n          </div>\n        </form>\n\n        <!-- Dynamic Success message -->\n        <div id=\"formSuccessMessage\" class=\"hidden absolute inset-0 bg-slate-900 border border-brand-indigo/30 rounded-2xl p-8 flex flex-col items-center justify-center text-center space-y-4 animate-fade-in relative z-25\">\n          <div class=\"w-16 h-16 rounded-full bg-slate-800 text-brand-indigoLight font-semibold border-brand-indigoLight/30 border-2 flex items-center justify-center text-2xl\">\n            \360\237\216\211\n          </div>\n          <h3 class=\"text-2xl font-display font-bold text-white\">You\'re Booked!</h3>\n          <!-- Custom success description -->\n          <p class=\"text-slate-300 max-w-md leading-relaxed text-sm md:text-base\">\n            Check your inbox for Next Steps instructions. The stoneVEIL scheduling concierge will reach out to you within the hour to coordinate your free audit session!\n          </p>\n          <div class=\"bg-brand-bgLight/5 p-4 rounded-lg border border-white/5 w-full max-w-sm mt-4 text-xs font-mono text-slate-400 text-left\">\n            <span class=\"text-brand-indigoLight font-bold\">\342\227\217 AUDIT ENGINE OUTCOME :</span> SUCCESS<br>\n            <span class=\"text-emerald-400 font-bold\">\342\227\217 LEAD ROUTED :</span> INTERNAL SCHEDULER<br>\n            <span class=\"text-yellow-400 font-bold\">\342\227\217 SLA GUARANTEE :</span> &lt; 24 HOUR TAT\n          </div>\n        </div>\n      </div>\n\n      <!-- Trust signals footer strip -->\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6 text-center text-slate-400 text-xs font-semibold uppercase tracking-wider border-t border-white/10 pt-8 mt-6\">\n        <div class=\"flex items-center justify-center space-x-2\">\n          <span>\360\237\224\222</span>\n          <span>Your data is never sold or shared</span>\n        </div>\n        <div class=\"flex items-center justify-center space-x-2\">\n          <span>\360\237\223\205</span>\n          <span>We\'ll reach out within 1 business day</span>\n        </div>\n        <div class=\"flex items-center justify-center space-x-2\">\n          <span>\342\234\205</span>\n          <span>No contracts, no commitment required</span>\n        </div>\n      </div>\n\n    </div>\n  </section>\n\n  <!-- SECTION 6: FAQ (Handle Objections) -->\n  <section class=\"py-24 px-6 bg-white\">\n    <div class=\"max-w-4xl mx-auto flex flex-col items-center space-y-16\">\n      \n      <!-- FAQ H2 -->\n      <div class=\"text-center max-w-3xl space-y-4\">\n        <h2 class=\"text-3xl md:text-4xl font-display font-bold text-brand-navy\">Common Questions</h2>\n        <p class=\"text-lg text-slate-600\">Addressing common objections and clarifying the operational scope of stoneVEIL automations.</p>\n      </div>\n\n      <!-- Accordion Grid -->\n      <div class=\"w-full space-y-4\">\n        \n        <!-- Accordion Question 1 -->\n        <div class=\"border border-slate-150 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200\">\n          <button class=\"w-full py-5 px-6 flex items-center justify-between text-left focus:outline-none focus:bg-slate-50 transition-colors font-display font-bold text-brand-navy leading-snug md:text-lg\" onclick=\"toggleAccordion(this)\">\n            <span>How long does it take to deploy an automation?</span>\n            <span class=\"text-brand-indigo font-bold transform transition-transform duration-200 text-xl ml-4 shrink-0\">&plus;</span>\n          </button>\n          <div class=\"accordion-content bg-slate-50/50\">\n            <div class=\"p-6 text-sm text-slate-600 leading-relaxed border-t border-slate-100 space-y-3\">\n              <p>Simple integrations\342\200\224such as linking Web Forms straight to HubSpot CRM, building Slack triggers, or custom customer onboarding dispatches\342\200\224can go live in <strong>3 to 5 business days</strong>.</p>\n              <p>Complete multi-app systems with AI database scoring might require 2 weeks of engineering. We coordinate everything in your audit session first. <a href=\"#audit-form-section\" class=\"text-brand-indigo font-medium hover:underline\">Start with an audit &rarr;</a></p>\n            </div>\n          </div>\n        </div>\n\n        <!-- Accordion Question 2 -->\n        <div class=\"border border-slate-150 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200\">\n          <button class=\"w-full py-5 px-6 flex items-center justify-between text-left focus:outline-none focus:bg-slate-50 transition-colors font-display font-bold text-brand-navy leading-snug md:text-lg\" onclick=\"toggleAccordion(this)\">\n            <span>Do I need technical skills to use this?</span>\n            <span class=\"text-brand-indigo font-bold transform transition-transform duration-200 text-xl ml-4 shrink-0\">&plus;</span>\n          </button>\n          <div class=\"accordion-content bg-slate-50/50\">\n            <div class=\"p-6 text-sm text-slate-600 leading-relaxed border-t border-slate-100 space-y-3\">\n              <p><strong>Absolutely not.</strong> We design every automation to run completely hands-free in the background. If manual intervention is needed (like reviewing an AI draft before it publishes), we provide a super-simple, humdrum dashboard with clean, literal buttons.</p>\n              <p>We write and maintain all code on the backend, making usage dead-simple for you and your crew. <a href=\"#audit-form-section\" class=\"text-brand-indigo font-medium hover:underline\">Learn more in your free call &rarr;</a></p>\n            </div>\n          </div>\n        </div>\n\n        <!-- Accordion Question 3 -->\n        <div class=\"border border-slate-150 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200\">\n          <button class=\"w-full py-5 px-6 flex items-center justify-between text-left focus:outline-none focus:bg-slate-50 transition-colors font-display font-bold text-brand-navy leading-snug md:text-lg\" onclick=\"toggleAccordion(this)\">\n            <span>What tools and software do you integrate with?</span>\n            <span class=\"text-brand-indigo font-bold transform transition-transform duration-200 text-xl ml-4 shrink-0\">&plus;</span>\n          </button>\n          <div class=\"accordion-content bg-slate-50/50\">\n            <div class=\"p-6 text-sm text-slate-600 leading-relaxed border-t border-slate-100 space-y-3\">\n              <p>We integrate with virtually anything that has an API. This includes CRM systems (HubSpot, Salesforce, Pipedrive), messaging protocols (Slack, WhatsApp, Gmail, Twilio), databases (Airtable, SQL, Google Sheets), and standard billing stacks (Stripe, QuickBooks, Xero).</p>\n              <p>If your tooling is completely legacy, we can build custom micro-scripts to scrape or push data efficiently. <a href=\"#audit-form-section\" class=\"text-brand-indigo font-medium hover:underline\">Check compatible tools &rarr;</a></p>\n            </div>\n          </div>\n        </div>\n\n        <!-- Accordion Question 4 -->\n        <div class=\"border border-slate-150 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200\">\n          <button class=\"w-full py-5 px-6 flex items-center justify-between text-left focus:outline-none focus:bg-slate-50 transition-colors font-display font-bold text-brand-navy leading-snug md:text-lg\" onclick=\"toggleAccordion(this)\">\n            <span>How much does it cost?</span>\n            <span class=\"text-brand-indigo font-bold transform transition-transform duration-200 text-xl ml-4 shrink-0\">&plus;</span>\n          </button>\n          <div class=\"accordion-content bg-slate-50/50\">\n            <div class=\"p-6 text-sm text-slate-600 leading-relaxed border-t border-slate-100 space-y-3\">\n              <p>The discovery audit itself is completely <strong>0 USD</strong>. Practical custom, permanent automation creations scale according to system scopes (ranging from 1,200 USD setups for focused micro-pipelines up to recurring retainer plans for full boutique pipeline administration).</p>\n              <p>Every single deploy is meticulously scoped with guaranteed savings parameters before you spend a single dime. <a href=\"#audit-form-section\" class=\"text-brand-indigo font-medium hover:underline\">Get an exact quote on your call &rarr;</a></p>\n            </div>\n          </div>\n        </div>\n\n        <!-- Accordion Question 5 -->\n        <div class=\"border border-slate-150 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200\">\n          <button class=\"w-full py-5 px-6 flex items-center justify-between text-left focus:outline-none focus:bg-slate-50 transition-colors font-display font-bold text-brand-navy leading-snug md:text-lg\" onclick=\"toggleAccordion(this)\">\n            <span>What if I already have some software \342\200\224 can you work with it?</span>\n            <span class=\"text-brand-indigo font-bold transform transition-transform duration-200 text-xl ml-4 shrink-0\">&plus;</span>\n          </button>\n          <div class=\"accordion-content bg-slate-50/50\">\n            <div class=\"p-6 text-sm text-slate-600 leading-relaxed border-t border-slate-100 space-y-3\">\n              <p><strong>Yes, we prefer it.</strong> Our engineers match and weave programmatic hooks directly inside your current workflow. Our absolute core purpose is to streamline what you have, never forcing you to purchase separate unneeded tools or migrate away from elements you like.</p>\n              <p>We connect the loose strands to eliminate manual double-handling of data. <a href=\"#audit-form-section\" class=\"text-brand-indigo font-medium hover:underline\">Map your existing tools &rarr;</a></p>\n            </div>\n          </div>\n        </div>\n\n        <!-- Accordion Question 6 -->\n        <div class=\"border border-slate-150 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200\">\n          <button class=\"w-full py-5 px-6 flex items-center justify-between text-left focus:outline-none focus:bg-slate-50 transition-colors font-display font-bold text-brand-navy leading-snug md:text-lg\" onclick=\"toggleAccordion(this)\">\n            <span>What\'s the ROI I should expect?</span>\n            <span class=\"text-brand-indigo font-bold transform transition-transform duration-200 text-xl ml-4 shrink-0\">&plus;</span>\n          </button>\n          <div class=\"accordion-content bg-slate-50/50\">\n            <div class=\"p-6 text-sm text-slate-600 leading-relaxed border-t border-slate-100 space-y-3\">\n              <p>On average, stoneVEIL customers recapture <strong>11 hours per week per employee</strong> from tedious entry, scheduling overhead, and CRM maintenance. For a small crew of 5, that\'s equivalent to 2,800 saved labor hours annually.</p>\n              <p>Most projects recoup their entire initialization costs within 30 days of implementation. <a href=\"#audit-form-section\" class=\"text-brand-indigo font-medium hover:underline\">Calculate your actual ROI with us &rarr;</a></p>\n            </div>\n          </div>\n        </div>\n\n      </div>\n\n    </div>\n  </section>\n\n  <!-- SECTION 7: FINAL CTA STRIP -->\n  <section class=\"py-20 px-6 bg-brand-navy text-white text-center border-t border-white/5 relative overflow-hidden\">\n    <!-- Fluid light highlight -->\n    <div class=\"absolute bottom-0 left-1/2 -translate-x-1/2 w-[500px] h-[150px] bg-brand-indigo/10 rounded-full blur-[90px] pointer-events-none\"></div>\n    \n    <div class=\"max-w-4xl mx-auto relative z-10 flex flex-col items-center space-y-6\">\n      <h2 class=\"text-3xl md:text-4xl font-display font-bold text-white max-w-2xl leading-snug\">\n        Ready to stop doing manually what automation can do for you?\n      </h2>\n      <p class=\"text-slate-400 text-base md:text-lg max-w-xl leading-relaxed\">\n        Let us map your workflows and present a detailed savings model. Completely free, no obligations.\n      </p>\n      \n      <div class=\"pt-4\">\n        <a href=\"#audit-form-section\" class=\"bg-brand-amber hover:bg-amber-500 text-brand-navy font-bold text-center py-4 px-8 rounded-lg shadow-xl shadow-amber-500/20 transition-all duration-200 transform hover:-translate-y-0.5 inline-block text-base\">\n          Book Your Free Workflow Audit &rarr;\n        </a>\n      </div>\n      \n      <p class=\"text-xs text-slate-500 pt-2 font-mono\">\n        Or email us directly: <a href=\"mailto:origin@stoneveil.io\" class=\"text-brand-indigoLight hover:underline font-semibold\">origin@stoneveil.io</a> <!-- [REPLACE: direct email address] -->\n      </p>\n    </div>\n  </section>\n\n  <!-- FOOTER -->\n  <footer class=\"bg-brand-navy border-t border-white/5 py-12 px-6 text-slate-400 text-center text-sm\">\n    <div class=\"max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6\">\n      <!-- Left: Logo & copyright -->\n      <div class=\"flex flex-col items-center md:items-start space-y-2\">\n        <span class=\"font-display font-bold text-white text-lg tracking-tight\">stone<span class=\"text-brand-indigo\">VEIL</span> Operations LLC</span>\n        <p class=\"text-xs text-slate-500\">Automate the busywork. Run the business. &copy; <span id=\"currentYear\">2026</span> stoneVEIL Operations LLC.</p>\n      </div>\n      \n      <!-- Right: Links & social indicators -->\n      <div class=\"flex items-center space-x-6\">\n        <a href=\"#\" class=\"hover:text-white transition duration-200\">Privacy Policy</a> <!-- [REPLACE: Privacy Link] -->\n        <a href=\"#\" class=\"hover:text-white transition duration-200 flex items-center space-x-1.5\">\n          <svg class=\"w-4 h-4 text-slate-400 hover:text-white\" fill=\"currentColor\" currentColor=\"white\" viewBox=\"0 0 24 24\" width=\"24\" height=\"24\">\n            <path d=\"M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z\"/>\n          </svg>\n          <span>LinkedIn</span>\n        </a> <!-- [REPLACE: LinkedIn Link] -->\n      </div>\n    </div>\n  </footer>\n\n  <!-- MOBILE STATIC STICKY BOTTOM CAPTURE BAR -->\n  <div id=\"stickyBottomBar\" class=\"fixed bottom-0 inset-x-0 bg-brand-navy/95 border-t border-white/10 backdrop-blur-md px-6 py-4 flex items-center justify-between text-white z-40 md:hidden transition-transform duration-300 translate-y-full\">\n    <div class=\"flex flex-col\">\n      <span class=\"text-xs uppercase font-mono text-brand-amber font-semibold tracking-wider\">Free discovery</span>\n      <span class=\"text-xs font-semibold text-slate-300\">Workflow audit call</span>\n    </div>\n    <a href=\"#audit-form-section\" class=\"bg-brand-amber hover:bg-amber-500 text-brand-navy font-extrabold text-xs px-4 py-2.5 rounded shadow-lg\">\n      Book Call\n    </a>\n  </div>\n\n  <!-- INTERACTIVE JAVASCRIPT LOGIC -->\n  <script>\n    // Set Year\n    document.getElementById(\'currentYear\').innerText = new Date().getFullYear();\n\n    // Accordion Expansion Trigger\n    function toggleAccordion(button) {\n      const parent = button.parentElement;\n      const isOpen = parent.classList.contains(\'accordion-open\');\n      const icon = button.querySelector(\'span:last-child\');\n      const content = button.nextElementSibling;\n      \n      // Close all other accordions first for clean progressive interaction\n      document.querySelectorAll(\'.accordion-open\').forEach(el => {\n        el.classList.remove(\'accordion-open\');\n        el.querySelector(\'button span:last-child\').innerHTML = \'&plus;\';\n        el.querySelector(\'.accordion-content\').style.maxHeight = \'0px\';\n      });\n\n      if (!isOpen) {\n        parent.classList.add(\'accordion-open\');\n        icon.innerHTML = \'&minus;\';\n        content.style.maxHeight = content.scrollHeight + \'px\';\n      } else {\n        parent.classList.remove(\'accordion-open\');\n        icon.innerHTML = \'&plus;\';\n        content.style.maxHeight = \'0px\';\n      }\n    }\n\n    // Scroll Fade-in Intersection Observer\n    document.addEventListener(\"DOMContentLoaded\", function() {\n      const sections = document.querySelectorAll(\'.fade-in-section\');\n      \n      // Seed first intersection trigger\n      const observerOptions = {\n        root: null,\n        threshold: 0.1,\n        rootMargin: \'0px 0px -50px 0px\'\n      };\n      \n      const observer = new IntersectionObserver((entries, observer) => {\n        entries.forEach(entry => {\n          if (entry.isIntersecting) {\n            entry.target.classList.add(\'is-visible\');\n            observer.unobserve(entry.target);\n          }\n        });\n      }, observerOptions);\n      \n      // Observe all section blocks\n      sections.forEach(s => observer.observe(s));\n      \n      // Apply fade-in classes retrospectively for smooth JS transitions\n      document.querySelectorAll(\'section:not(:first-of-type)\').forEach(s => {\n        s.classList.add(\'fade-in-section\');\n        observer.observe(s);\n      });\n    });\n\n    // Mobile Bottom Sticky Bar Behavior on Scroll Depth (> 50% scroll)\n    window.addEventListener(\'scroll\', function() {\n      const bar = document.getElementById(\'stickyBottomBar\');\n      const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;\n      const scrollPercent = (window.scrollY / scrollHeight) * 100;\n      \n      if (scrollPercent > 35 && window.innerWidth < 768) {\n        bar.classList.remove(\'translate-y-full\');\n      } else {\n        bar.classList.add(\'translate-y-full\');\n      }\n    });\n\n    // Lead capturing submission handler\n    function handleFormSubmission(event) {\n      event.preventDefault();\n      \n      // Gather inputs\n      const name = document.getElementById(\'fullName\').value;\n      const email = document.getElementById(\'businessEmail\').value;\n      const company = document.getElementById(\'companyName\').value;\n      const phone = document.getElementById(\'phoneNumber\').value;\n      const strain = document.getElementById(\'timeDrain\').value;\n      const process = document.getElementById(\'processDetails\').value;\n      \n      // Simulate API submit delay for real-world confidence modeling\n      const button = event.target.querySelector(\'button[type=\"submit\"]\');\n      const originalText = button.innerHTML;\n      button.disabled = true;\n      button.innerHTML = `\n        <span class=\"inline-flex items-center space-x-2\">\n          <svg class=\"animate-spin -ml-1 mr-3 h-5 w-5 text-brand-navy\" xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\">\n            <circle class=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" stroke-width=\"4\"></circle>\n            <path class=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\"></path>\n          </svg>\n          Processing Audit Criteria...\n        </span>\n      `;\n      \n      // Post criteria to server if running inside developer sandbox\n      fetch(\'/api/lead\', {\n        method: \'POST\',\n        headers: { \'Content-Type\': \'application/json\' },\n        body: JSON.stringify({ name, email, company, phone, strain, process })\n      })\n      .then(response => response.json())\n      .then(data => {\n        // Log lead outcomes or load custom prompt predictions\n        console.log(\"Lead captured safely:\", data);\n        \n        // Show Success card\n        setTimeout(() => {\n          document.getElementById(\'formSuccessMessage\').classList.remove(\'hidden\');\n        }, 1200);\n      })\n      .catch(error => {\n        console.warn(\"Server API routing offline, executing fallback client-side success handler:\", error);\n        \n        // Non-blocking fallback\n        setTimeout(() => {\n          document.getElementById(\'formSuccessMessage\').classList.remove(\'hidden\');\n        }, 1500);\n      });\n    }\n  </script>\n\n</body>\n</html>\n\n<!--\n\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\n                    INTEGRATION NOTES (DEVELOPER WORKBENCH)\n\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\nThis custom landing page is structured for instant copy-paste deployment.\nTo hook this up to your real-world B2B operational systems, proceed with\none of the following integration guide patterns:\n\n(a) WIRE FORM TO BACKEND ENDPOINT / DATABASE\nTo store lead inputs directly in a relational system (such as Supabase, PostgreSQL,\nor Neon Postgres), deploy any simple Node / Python body parser route. For client-side\nstandalone submits, replace the fetch url in handleFormSubmission() with your cloud route:\n\nexample standard capture endpoint:\n    fetch(\'https://api.yourdomain.com/v1/leads\', {\n      method: \'POST\',\n      headers: { \'Content-Type\': \'application/json\' },\n      body: JSON.stringify({ name, email, company, phone, strain, process })\n    });\n\n(b) CONNECT TO B2B CRM VIA WEBHOOKS (HubSpot, Pipedrive, Zapier)\nFor marketing operations alignment, trigger a central automation webhook. In Zapier,\ninstantiate a \"Catch Webhook\" trigger node, copy the provided direct hook URL, and fetch it:\n\n    url = \"https://hooks.zapier.com/hooks/catch/12345/abcde/\";\n    fetch(url, { method: \"POST\", mode: \"no-cors\", body: JSON.stringify(...) });\n\nZapier actions mapping guidelines:\n- Create CRM Contact in Pipedrive/HubSpot using fields {email}, {name}.\n- Store Custom Lead Properties for {company} and {phone}.\n- Dispatch instant Slack channel notification summarizing the pain point:\n  \"\360\237\232\250 New Lead Capture from stoneVEIL: {name} (Company: {company}). Biggest operation pain: {strain}. Details: {process}.\"\n\n(c) GENERATE AI-POWERED LEAD SCORING & AUTOMATED RECOMMENDATIONS\nTo qualify leads asynchronously, feed inputs into Gemini\'s text capabilities using\nour server-side module. We qualify lead intent using \'gemini-3.5-flash\', scoring and\nsuggesting 3 custom immediate automations based on what they self-selected!\n\nSafe Server-Side Code snippet (Express endpoint):\n```typescript\nimport { GoogleGenAI } from \"@google/genai\";\nconst ai = new GoogleGenAI({ apiKey: process.env.GEMINI_API_KEY });\n\napp.post(\'/api/lead\', async (req, res) => {\n  const { name, email, company, strain, process } = req.body;\n  \n  const systemInstruction = `\n    You are a Conversion and Growth Engineer. Analyze lead details and issue:\n    1. A LEAD SCORE rating (Low, Medium, High value based on operational scope).\n    2. Exactly 3 custom automation ideas tailored to their biggest pain point: \"${strain}\" and current process: \"${process}\".\n    Keep answers humble, scannable, and extremely practical for busy SMB owners. Include brief ROI estimates.\n  `;\n  \n  const response = await ai.models.generateContent({\n    model: \"gemini-3.5-flash\",\n    contents: `Analyze company \"${company}\" led by \"${name}\". They struggle with: \"${strain}\". Details: \"${process}\".`,\n    config: { systemInstruction }\n  });\n  \n  const outcomeText = response.text;\n  \n  // Custom action: Save outcomeText in CRM or use custom mail trigger (Resend / SendGrid)\n  // to email the customized Workflow recommendation plan to \'email\' within 5 minutes!\n  res.json({ success: true, analysis: outcomeText });\n});\n```\n\n(d) RECOMMENDED A/B TEST DESIGNS\nTo maximize lead capture and push conversions past 20%, run these test designs:\n- Test 1 (Headline Frame): Compare \"Stop Losing 15 Hrs/Week to Busywork\" against\n  \"Let AI Run Your Admin. 24/7 Custom Workflows in 5 Days.\"\n- Test 2 (Form CTA Labeling): Compare amber full-width \"Book My Free Audit \342\206\222\"\n  against higher commitment label \"Claim your Custom Automation Strategy \342\206\222\".\n- Test 3 (Progressive Fields): Test removing the custom textarea {processDetails} to check\n  if minimal text fields lower lead intake bounce rates.\n\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\342\224\201\n-->\n"
    }
