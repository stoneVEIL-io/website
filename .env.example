# Copy to .env and fill in. .env is git-ignored — never commit real secrets.

# --- AI audit provider ---
# Key for the AI model used by the audit + demo-copy generation (lib/ai.ts).
AI_API_KEY="your-ai-api-key"
# Optional: override the model id (defaults to a fast general model).
# AI_MODEL="gemini-2.0-flash"

# --- Database (Neon Postgres) ---
# Server-side only. Get this from your Neon project dashboard.
DATABASE_URL="postgresql://<user>:<password>@<host>.neon.tech/<db>?sslmode=require"

# --- App ---
# Public URL where this app is hosted.
APP_URL="https://stoneveil.io"

# --- Google Places API ---
# Fetches contractor GBP data (reviews, hours, services, photos).
# Enable the Places API in a GCP project with billing; set a budget alert.
GOOGLE_PLACES_API_KEY="your-places-api-key"

# --- Email transport (Resend) ---
# Free up to 3K emails/mo. Requires a verified sending domain.
RESEND_API_KEY="your-resend-api-key"
# Friendly From line, e.g. "Stoneveil Audits <intake@stoneveil.io>"
EMAIL_FROM="Stoneveil Audits <intake@example.com>"

# --- Calendly ---
# Public event-type URL of the "Discovery Call — 15 min" event.
# Supports ?name= and ?email= query params for prefill.
CALENDLY_URL="https://calendly.com/your-handle/discovery-15"

# --- Admin ---
# Password for /admin/* (HTTP Basic Auth). If unset, those routes return 404.
ADMIN_PASSWORD="choose-a-strong-password"
