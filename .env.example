# --- AI ---
# GEMINI_API_KEY: Required for Gemini API calls (audit + qualification).
# AI Studio injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# --- App ---
# APP_URL: Where this applet is hosted. AI Studio injects the Cloud Run URL at runtime.
APP_URL="MY_APP_URL"

# --- Database (Neon REST) ---
# Server-side only. Auth token is sent in Authorization header by Drizzle.
# DATABASE_URL="https://<your-neon-rest-endpoint>/neondb/rest/v1"

# --- Google Places API (Phase 0 / Task 0.1) ---
# Used to fetch contractor GBP data (reviews, hours, services, photos).
# Get a key from a GCP project with Places API enabled + billing attached.
# Set a $20/mo GCP budget alert as a safety net.
GOOGLE_PLACES_API_KEY="MY_PLACES_API_KEY"

# --- Email transport (Phase 2 / Task 2.3) ---
# Resend, free up to 3K emails/mo. Requires a verified sending domain.
RESEND_API_KEY="MY_RESEND_API_KEY"
# Friendly From line, e.g.  "Stoneveil Audits <audits@stoneveil.com>"
EMAIL_FROM="Stoneveil Audits <audits@example.com>"

# --- Calendly (Phase 2 / Task 2.3) ---
# Public event-type URL of the "Discovery Call — 15 min" event.
# Supports ?name= and ?email= query params for prefill.
CALENDLY_URL="https://calendly.com/your-handle/discovery-15"

# --- Admin (Phase 4 / Demo amplifier) ---
# Password for the /admin/demo route (HTTP Basic Auth). If unset, route returns 404.
ADMIN_PASSWORD="choose-a-strong-password"
